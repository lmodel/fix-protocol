    {field} message_format : ClearingServiceForPostTradeProcessingEnum  
    {field} supported_actions : string  [1..*]
}
class "AllocationFragmentationFieldMap" [[{One row of the table mapping an allocation message to its fragmentation-related fields.}]] {
    {field} msg_type : string  
    {field} message_name : string  
    {field} total_count_field : string  
    {field} fragment_count_field : string  
