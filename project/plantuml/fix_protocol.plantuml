class "MessageCategory" [[{A message category within a business area.}]] {
    {field} category : MessageCategoryEnum  
    {field} title : string  
    {field} description : string  
    {field} business_area : BusinessAreaEnum  
}
class "Message" [[{A FIX application message.}]] {
    {field} msg_type : string  
    {field} message_name : string  
    {field} description : string  
    {field} category : MessageCategoryEnum  
}
class "BusinessArea" [[{A top-level business area of the FIX Latest specification.}]] {
    {field} area : BusinessAreaEnum  
    {field} title : string  
    {field} description : string  
}
"MessageCategory" *--> "0..*" "Message" : "messages"
"BusinessArea" *--> "0..*" "MessageCategory" : "categories"
abstract "Component" [[{A FIX component — a named set of related fields.}]] {
    {field} component_name : string  
    {field} description : string  
    {field} scope : ComponentScope  
    {field} is_repeating_group : boolean  
}
class "Field" [[{A FIX field — a uniquely tagged data element with a FIX datatype.}]] {
    {field} tag : TagNumber  
    {field} field_name : string  
    {field} datatype : FIXDatatypeName  
    {field} description : string  
    {field} requirement : FieldRequirement  
    {field} is_user_defined : boolean  
}
class "InfrastructureCategorySection" [[{A "Category – <name>" sub-section of the Infrastructure chapter.}]] {
    {field} category : InfrastructureCategoryEnum  
    {field} title : string  
    {field} description : string  
    {field} category_components_note : string  
    {field} network_status_scenarios : NetworkStatusScenarioEnum  [0..*]
    {field} network_request_types_referenced : NetworkRequestTypeEnum  [0..*]
    {field} application_message_report_uses : ApplicationMessageReportTypeEnum  [0..*]
}
"Message" --> "0..*" "Component" : "components"
"Message" *--> "0..*" "Field" : "fields"
