"InfrastructureCategorySection" *--> "0..*" "InfrastructureComponentDetail" : "infra_category_specific_components"
"InfrastructureBusinessArea" *--> "0..*" "InfrastructureCategorySection" : "infra_category_sections"
class "BusinessRejectReasonDescription" [[{One entry of the BusinessRejectReason(380) code table.}]] {
    {field} reject_reason_code : integer  
    {field} reject_reason_label : string  
}
class "ApplicationMessageReferenceKey" [[{One row of a "Key Fields for <area> Application Message References" table identifying the field whose value is copied into BusinessRejectRefID(379).}]] {
    {field} category_label : string  
    {field} fix_message : string  
    {field} business_reject_ref_id_value : string  
}
"InfrastructureBusinessArea" --> "0..*" "GlobalComponent" : "referenced_global_components"
"InfrastructureBusinessArea" *--> "0..*" "BusinessRejectReasonDescription" : "business_reject_reason_descriptions"
"InfrastructureBusinessArea" *--> "0..*" "ApplicationMessageReferenceKey" : "key_fields_post_trade"
"InfrastructureBusinessArea" *--> "0..*" "ApplicationMessageReferenceKey" : "key_fields_trade"
"InfrastructureBusinessArea" *--> "0..*" "ApplicationMessageReferenceKey" : "key_fields_pre_trade"
"FIXIntroduction" *--> "0..*" "GlobalComponent" : "global_components"
"Component" ^-- "GlobalComponent"
"Component" *--> "0..*" "Field" : "fields"
class "FIXProtocolLimited" [[{The organization that maintains the FIX Protocol specification.}]] {
    {field} brand_name : string  
    {field} legal_name : string  
    {field} website : uri  
    {field} member_firms_url : uri  
    {field} working_groups_url : uri  
    {field} committees_url : uri  
    {field} member_types : FPLMemberType  [0..*]
    {field} governance_bodies : FPLCommitteeRole  [0..*]
    {field} product_committees : FPLProductGroup  [0..*]
    {field} regional_committees : FPLRegion  [0..*]
}
"FIXIntroduction" *--> "0..1" "FIXProtocolLimited" : "about_fpl"
class "FIXDatatype" [[{A FIX Protocol datatype.}]] {
    {field} datatype_name : FIXDatatypeName  
    {field} definition : string  
    {field} value_space : ISO11404ValueSpace  [0..*]
    {field} value_space_notes : string  
    {field} deprecated_for_new_designs : boolean  
    {field} external_code_set : string  
    {field} time_unit : TimePrecision  [0..*]
    {field} radix : integer  
    {field} repertoire : string  
    {field} index_lower_bound : integer  
    {field} index_upper_bound : integer  
    {field} minimum_value : integer  
    {field} maximum_value : integer  
    {field} footnote_numbers : integer  [0..*]
}
class "ExtensionPack" [[{A unit of change to FIX Latest.}]] {
    {field} number : ExtensionPackNumber  
    {field} title : string  
    {field} size : ExtensionPackSize  
    {field} enhancement_summary : string  
    {field} applies_to_session_layer_only : boolean  
    {field} applies_to_fixml_only : boolean  
}
class "FIXFamilyStandard" [[{A member standard of the FIX Family of Standards.}]] {
    {field} id : string  
    {field} name : string  
    {field} description : string  
    {field} acronym : string  
    {field} see_also : uri  [0..*]
    {field} layer : StandardLayer  
    {field} version : string  
    {field} session_profile : SessionProtocolName  
    {field} encoding_name : StandardEncodingName  
}
"FIXIntroduction" *--> "0..*" "BusinessArea" : "business_areas"
"FIXIntroduction" *--> "0..*" "FIXDatatype" : "datatypes"
"FIXIntroduction" *--> "0..*" "ExtensionPack" : "extension_packs"
"FIXIntroduction" *--> "0..*" "FIXFamilyStandard" : "standards"
class "SpecificComponent" [[{A component used only by messages within a single category.}]] {
    {field} business_area : BusinessAreaEnum  
    {field} category : MessageCategoryEnum  
    {field} scope : ComponentScope  
    {field} component_name(i) : string  
    {field} description(i) : string  
    {field} is_repeating_group(i) : boolean  
}
class "CommonComponent" [[{A component used only by messages within a single business area.}]] {
    {field} business_area : BusinessAreaEnum  
    {field} scope : ComponentScope  
    {field} component_name(i) : string  
    {field} description(i) : string  
    {field} is_repeating_group(i) : boolean  
}
"Component" --> "0..*" "Component" : "nested_components"
"PreTradeBusinessArea" --> "0..*" "Component" : "components"(i)
"TradeBusinessArea" --> "0..*" "Component" : "components"(i)
"TradeAppendixSection" --> "0..*" "Component" : "components"(i)
"PostTradeBusinessArea" --> "0..*" "Component" : "components"(i)
"InfrastructureBusinessArea" --> "0..*" "Component" : "components"(i)
"Component" ^-- "SpecificComponent"
"Component" ^-- "CommonComponent"
@enduml
