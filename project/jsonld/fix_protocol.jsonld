          "text": "TRADE"
        },
        {
          "text": "POST_TRADE"
        },
        {
          "text": "INFRASTRUCTURE"
        }
      ]
    },
    {
      "name": "MessageCategoryEnum",
      "definition_uri": "https://w3id.org/lmodel/fix-protocol/fix-base/MessageCategoryEnum",
      "description": "Message categories defined within FIX Latest business areas.",
      "from_schema": "https://w3id.org/lmodel/fix-protocol/fix-base",
      "related_mappings": [
        "fix_orchestra:CategoryType"
      ],
      "permissible_values": [
        {
          "text": "INDICATION"
