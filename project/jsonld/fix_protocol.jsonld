        },
        {
          "text": "INFRASTRUCTURE"
        }
      ]
    },
    {
      "name": "BusinessAreaEnum",
      "definition_uri": "https://w3id.org/lmodel/fix-protocol/fix-base/BusinessAreaEnum",
      "description": "Top-level business areas of the FIX Latest specification.",
      "from_schema": "https://w3id.org/lmodel/fix-protocol/fix-base",
      "related_mappings": [
        "fix_orchestra:CategoryType"
      ],
      "permissible_values": [
        {
          "text": "INTRODUCTION"
        },
        {
          "text": "PRE_TRADE"
        },
