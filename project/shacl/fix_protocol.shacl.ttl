@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix iso10383: <https://www.iso.org/standard/61067.html#> .
@prefix iso3166: <https://www.iso.org/iso-3166-country-codes.html#> .
@prefix iso4217: <https://www.iso.org/iso-4217-currency-codes.html#> .
@prefix iso639: <https://www.iso.org/iso-639-language-codes.html#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema1: <http://schema.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/fix-protocol/fix-base/CommonComponent> a sh:NodeShape ;
    rdfs:comment "A component used only by messages within a single business area." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
            sh:description "Components nested within this component." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/nested_components> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the component is a repeating group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/is_repeating_group> ],
        [ sh:datatype xsd:string ;
            sh:description "PascalCase name of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Field> ;
            sh:description "Fields directly contained by the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/fields> ],
        [ sh:defaultValue "COMMON" ;
            sh:description "Sharing scope of the component." ;
            sh:in ( "GLOBAL" "COMMON" "SPECIFIC" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/scope> ],
        [ sh:description "Business area the element belongs to." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/CommonComponent> .

<https://w3id.org/lmodel/fix-protocol/fix-base/FIXIntroduction> a sh:NodeShape ;
    rdfs:comment "Container for the structural elements of the FIX Latest Introduction section. Tree root for instance data." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/BusinessArea> ;
            sh:description "Top-level business areas of FIX Latest." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/business_areas> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/UDFTagRange> ;
            sh:description "Reserved ranges of user-defined-field tag numbers." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/udf_ranges> ],
        [ sh:description "Product/asset classes covered by FIX at the application layer." ;
            sh:in ( "EQUITIES" "CIV" "DERIVATIVES" "FIXED_INCOME" "FOREIGN_EXCHANGE" ) ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/product_coverage> ],
        [ sh:datatype xsd:string ;
            sh:description "The Preface text of the specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/preface> ],
        [ sh:datatype xsd:string ;
            sh:description "Prose note on UTC leap-second handling for UTCTimestamp." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/utc_leap_seconds_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/FIXProtocolLimited> ;
            sh:description "Information about FIX Protocol Limited." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/about_fpl> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/ExtensionPack> ;
            sh:description "The list of Extension Packs." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/extension_packs> ],
        [ sh:datatype xsd:string ;
            sh:description "Version stamp from the document header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:version ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/FIXDatatype> ;
            sh:description "FIX Protocol datatype definitions and value spaces." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/datatypes> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Global Technical Committee"^^xsd:string ;
            sh:description "Publishing body of the FIX Latest specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:publisher ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/FIXFamilyStandard> ;
            sh:description "The FIX Family of Standards." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/standards> ],
        [ sh:datatype xsd:string ;
            sh:description "The Introduction prose section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/introduction_text> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> ;
            sh:description "Global Components defined in the Introduction." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/global_components> ],
        [ sh:datatype xsd:date ;
            sh:description "Publication date of the document." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:issued ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/FIXIntroduction> .

<https://w3id.org/lmodel/fix-protocol/fix-base/SpecificComponent> a sh:NodeShape ;
    rdfs:comment "A component used only by messages within a single category." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Field> ;
            sh:description "Fields directly contained by the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/fields> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the component is a repeating group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/is_repeating_group> ],
        [ sh:description "Message category." ;
            sh:in ( "INDICATION" "EVENT_COMMUNICATION" "QUOTATION_NEGOTIATION" "MARKET_DATA" "MARKET_STRUCTURE_REFERENCE_DATA" "SECURITIES_REFERENCE_DATA" "PARTIES_REFERENCE_DATA" "PARTIES_ACTION" "SINGLE_GENERAL_ORDER_HANDLING" "ORDER_MASS_HANDLING" "CROSS_ORDERS" "MULTILEG_ORDERS" "LIST_PROGRAM_BASKET_TRADING" "ALLOCATION_AND_READY_TO_BOOK" "CONFIRMATION" "SETTLEMENT_INSTRUCTIONS" "TRADE_CAPTURE_REPORTING" "REGISTRATION_INSTRUCTIONS" "POSITIONS_MAINTENANCE" "COLLATERAL_MANAGEMENT" "MARGIN_REQUIREMENT_MANAGEMENT" "ACCOUNT_REPORTING" "TRADE_MANAGEMENT" "PAY_MANAGEMENT" "SETTLEMENT_STATUS_MANAGEMENT" "BUSINESS_MESSAGE_REJECTS" "NETWORK_STATUS_COMMUNICATION" "USER_MANAGEMENT" "APPLICATION_SEQUENCING" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/category> ],
        [ sh:datatype xsd:string ;
            sh:description "PascalCase name of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:description "Business area the element belongs to." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ sh:defaultValue "SPECIFIC" ;
            sh:description "Sharing scope of the component." ;
            sh:in ( "GLOBAL" "COMMON" "SPECIFIC" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/scope> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
            sh:description "Components nested within this component." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/nested_components> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/SpecificComponent> .

<https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureBusinessArea> a sh:NodeShape ;
    rdfs:comment "Tree-root container for the Infrastructure business area of FIX Latest." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/StandardResponseMapping> ;
            sh:description "\"Standard Responses for Pre-Trade Messages\" table rows." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/standard_responses_pre_trade> ],
        [ sh:datatype xsd:string ;
            sh:description "Prose introduction of the Infrastructure chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_introduction> ],
        [ sh:datatype xsd:string ;
            sh:description "Sentence describing diagram conventions used in the chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/diagram_conventions> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/ApplicationMessageReferenceKey> ;
            sh:description "\"Key Fields for Trade Application Message References\" table rows." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 17 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/key_fields_trade> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureMessageEntry> ;
            sh:description "Messages defined within the enclosing element." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/BusinessRejectReasonDescription> ;
            sh:description "Descriptions tied to BusinessRejectReason(380) values." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/business_reject_reason_descriptions> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureGlobalComponentReference> ;
            sh:description "Global Components (from the FIX Latest \"Global Components\" page) that are explicitly referenced by messages in the Infrastructure business area, together with their tag set and usage scope." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_global_components> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureCategorySection> ;
            sh:description "Per-category sub-sections of the Infrastructure chapter." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_category_sections> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> ;
            sh:description "Names of Global Components from the FIX Latest \"Global Components\" page that are referenced by messages in the containing business area. References instances of the :class:`GlobalComponent` class (declared in fix_base) by name." ;
            sh:nodeKind sh:IRI ;
            sh:order 21 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-global-components/referenced_global_components> ],
        [ sh:defaultValue "INFRASTRUCTURE" ;
            sh:description "Identity of the business area." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Version stamp from the document header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:version ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/ApplicationMessageReferenceKey> ;
            sh:description "\"Key Fields for Pre-Trade Application Message References\" table rows." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 16 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/key_fields_pre_trade> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureComponentEntry> ;
            sh:description "Components referenced by the enclosing element." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/components> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "Business Area Infrastructure"^^xsd:string ;
            sh:description "Display title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Components sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/components_overview_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/StandardResponseMapping> ;
            sh:description "\"Standard Responses for Post-Trade Messages\" table rows." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/standard_responses_post_trade> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/StandardResponseMapping> ;
            sh:description "\"Standard Responses for Trade Messages\" table rows." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/standard_responses_trade> ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Messages sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/messages_overview_note> ],
        [ sh:description "Component names declared in the area-wide components listing. Per the chapter prose, none of these are shared across categories within the area." ;
            sh:in ( "ApplIDReportGrp" "ApplIDRequestAckGrp" "ApplIDRequestGrp" "CompIDReqGrp" "CompIDStatGrp" "ThrottleMsgTypeGrp" "ThrottleParamsGrp" "UsernameGrp" ) ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_common_components> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/ApplicationMessageReferenceKey> ;
            sh:description "\"Key Fields for Post-Trade Application Message References\" table rows." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 18 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/key_fields_post_trade> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureComponentTableFootnote> ;
            sh:description "Footnotes attached to the area-wide Infrastructure components table." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_footnotes> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Global Technical Committee"^^xsd:string ;
            sh:description "Publishing body of the FIX Latest specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:publisher ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureBusinessArea> .

<https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeBusinessArea> a sh:NodeShape ;
    rdfs:comment "Tree-root container for the Post-Trade business area of FIX Latest." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeComponentEntry> ;
            sh:description "Components referenced by the enclosing element." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/components> ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Messages sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/messages_overview_note> ],
        [ sh:description "Common Components declared at the top of the Post-Trade chapter." ;
            sh:in ( "AllocCommissionDataGrp" "AllocRegulatoryTradeIDGrp" "ClrInstGrp" "CollateralAmountGrp" "CollateralReinvestmentGrp" "DlvyInstGrp" "ExecAllocGrp" "MarginAmount" "OrdAllocGrp" "PositionAmountData" "SettlDetails" "SettlInstructionsData" "SettlParties" "SettlPtysSubGrp" "TradeAllocAmtGrp" "TransactionAttributeGrp" ) ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_common_components> ],
        [ sh:datatype xsd:string ;
            sh:description "Prose introduction of the Post-Trade chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_introduction> ],
        [ sh:datatype xsd:string ;
            sh:description "Sentence describing diagram conventions used in the chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/diagram_conventions> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeMessageEntry> ;
            sh:description "Messages defined within the enclosing element." ;
            sh:minCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ sh:defaultValue "POST_TRADE" ;
            sh:description "Identity of the business area." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "Business Area Post-Trade"^^xsd:string ;
            sh:description "Display title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeComponentTableFootnote> ;
            sh:description "Footnotes attached to the area-wide components table." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_footnotes> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Global Technical Committee"^^xsd:string ;
            sh:description "Publishing body of the FIX Latest specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:publisher ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Components sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/components_overview_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> ;
            sh:description "Names of Global Components from the FIX Latest \"Global Components\" page that are referenced by messages in the containing business area. References instances of the :class:`GlobalComponent` class (declared in fix_base) by name." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-global-components/referenced_global_components> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeCommonComponentDetail> ;
            sh:description "Per-common-component descriptions from the chapter's final Common Components section." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_common_component_details> ],
        [ sh:datatype xsd:string ;
            sh:description "Version stamp from the document header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:version ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeCategorySection> ;
            sh:description "Per-category sub-sections of the Post-Trade chapter." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_category_sections> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeBusinessArea> .

<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/PreTradeBusinessArea> a sh:NodeShape ;
    rdfs:comment "Tree-root container for the Pre-Trade business area of FIX Latest." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Components sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/components_overview_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> ;
            sh:description "Names of Global Components from the FIX Latest \"Global Components\" page that are referenced by messages in the containing business area. References instances of the :class:`GlobalComponent` class (declared in fix_base) by name." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-global-components/referenced_global_components> ],
        [ sh:datatype xsd:string ;
            sh:description "Sentence describing diagram conventions used in the chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/diagram_conventions> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/PreTradeCategorySection> ;
            sh:description "Per-category sub-sections of the chapter." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/category_sections> ],
        [ sh:description "Common Components declared at the top of the chapter." ;
            sh:in ( "AuctionTypeRuleGrp" "BaseTradingRules" "ExecInstRules" "InstrumentScope" "InstrumentScopeGrp" "InstrumentScopeSecurityAltIDGrp" "LotTypeRules" "MarketDataFeedTypes" "MarketSegmentScopeGrp" "MatchRules" "OrdTypeRules" "PriceLimits" "PriceRangeRuleGrp" "QuoteSizeRuleGrp" "RequestedPartyRoleGrp" "RequestingPartyGrp" "RequestingPartySubGrp" "RoutingGrp" "TickRules" "TimeInForceRules" "TradingSessionRules" ) ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/common_components> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/CommonComponentDetail> ;
            sh:description "Per-common-component descriptions from the chapter's final section." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/common_component_details> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Global Technical Committee"^^xsd:string ;
            sh:description "Publishing body of the FIX Latest specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:publisher ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/PreTradeComponentEntry> ;
            sh:description "Area-wide pre-trade components table." ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/components> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "Business Area Pre-Trade"^^xsd:string ;
            sh:description "Display title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Messages sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/messages_overview_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/PreTradeMessageEntry> ;
            sh:description "Area-wide pre-trade messages table." ;
            sh:nodeKind sh:IRI ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ sh:defaultValue "PRE_TRADE" ;
            sh:description "Identity of the business area." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Version stamp from the document header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:version ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/ComponentTableFootnote> ;
            sh:description "Footnotes attached to the area-wide components table." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/footnotes> ],
        [ sh:datatype xsd:string ;
            sh:description "Prose introduction of the chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/introduction> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/PreTradeBusinessArea> .

<https://w3id.org/lmodel/fix-protocol/fix-trade/TradeAppendix> a sh:NodeShape ;
    rdfs:comment "Tree-root container for the Trade Appendix — the spec companion document that publishes the full message- and component-layout tables for every message and component used in the Trade business area, organized into one \"Appendix – <X> Category\" sub-section per Trade category plus a final \"Appendix – Common Category\" sub-section covering the layouts of the chapter's common components." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Optional preface prose for the Trade Appendix as a whole." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:string ;
            sh:description "Version stamp from the document header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:version ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "Trade Appendix"^^xsd:string ;
            sh:description "Display title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:title ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeAppendixSection> ;
            sh:description "Per-category sub-sections of the Trade Appendix — one \"Appendix – <X> Category\" section per Trade category, plus a synthetic \"Common Category\" section that lists layouts of the chapter's common components." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_appendix_sections> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Global Technical Committee"^^xsd:string ;
            sh:description "Publishing body of the FIX Latest specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:publisher ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeAppendix> .

<https://w3id.org/lmodel/fix-protocol/fix-trade/TradeBusinessArea> a sh:NodeShape ;
    rdfs:comment "Tree-root container for the Trade (Orders and Executions) business area of FIX Latest." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Prose introduction of the chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_introduction> ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Components sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_components_overview_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeMessageEntry> ;
            sh:description "Area-wide trade messages table." ;
            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "Business Area Trade"^^xsd:string ;
            sh:description "Display title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:string ;
            sh:description "Intro prose of the area-wide Messages sub-section." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_messages_overview_note> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Global Technical Committee"^^xsd:string ;
            sh:description "Publishing body of the FIX Latest specification." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:publisher ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeComponentTableFootnote> ;
            sh:description "Footnotes attached to the area-wide components table." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_footnotes> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeComponentEntry> ;
            sh:description "Area-wide trade components table." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/components> ],
        [ sh:description "Common Components declared at the bottom of the chapter." ;
            sh:in ( "DisclosureInstructionGrp" "DiscretionInstructions" "PegInstructions" "PreAllocGrp" "StrategyParametersGrp" "TriggeringInstruction" ) ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_common_components> ],
        [ sh:defaultValue "TRADE" ;
            sh:description "Identity of the business area the chapter describes." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Sentence describing diagram conventions used in the chapter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_diagram_conventions> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeCommonComponentDetail> ;
            sh:description "Per-common-component descriptions from the chapter's final section." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_common_component_details> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeCategorySection> ;
            sh:description "Per-category sub-sections of the chapter." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_category_sections> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> ;
            sh:description "Names of Global Components from the FIX Latest \"Global Components\" page that are referenced by messages in the containing business area. References instances of the :class:`GlobalComponent` class (declared in fix_base) by name." ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-global-components/referenced_global_components> ],
        [ sh:datatype xsd:string ;
            sh:description "Version stamp from the document header." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path schema1:version ],
        [ sh:description "URL of the \"Message Diagram Templates\" page referenced by the chapter introduction." ;
