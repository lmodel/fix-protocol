    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "FIX datatype of the field." ;
            sh:in ( "int" "TagNum" "SeqNum" "NumInGroup" "DayOfMonth" "float" "Qty" "Price" "PriceOffset" "Amt" "Percentage" "char" "Boolean" "String" "MultipleCharValue" "MultipleStringValue" iso3166: iso4217: iso10383: "MonthYear" "UTCTimestamp" "UTCTimeOnly" "UTCDateOnly" "LocalMktDate" "TZTimeOnly" "TZTimestamp" "Length" "data" "Tenor" "Reserved100Plus" "Reserved1000Plus" "Reserved4000Plus" "XMLData" iso639: "LocalMktTime" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/datatype> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the field is a User Defined Field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/is_user_defined> ],
        [ sh:datatype xsd:integer ;
            sh:description "Numeric tag of the field." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/tag> ],
        [ sh:datatype xsd:string ;
            sh:description "PascalCase name of the field." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the field's purpose." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path dcterms:description ],
        [ sh:description "Required-status of the field within the enclosing context." ;
            sh:in ( "REQUIRED" "OPTIONAL" "CONDITIONALLY_REQUIRED" ) ;
            sh:maxCount 1 ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/requirement> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/Field> .

<https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> a sh:NodeShape ;
    rdfs:comment "A component shared by messages of two or more business areas." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "PascalCase name of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path schema1:name ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
            sh:description "Components nested within this component." ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/nested_components> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Applicable at the UnderlyingInstrument level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_underlying> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Applicable at the InstrumentLeg level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_leg> ],
        [ sh:datatype xsd:integer ;
            sh:description "Numeric component identifier extracted from the FIX Latest \"Global Components\" page anchor ID (e.g. \"comp1057-1\" → 1057). Stable across Extension Packs and shared with the FIX Orchestra repository." ;
            sh:maxCount 1 ;
            sh:minInclusive 0 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/gc_id> ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:description ],
        [ sh:description "Thematic group under which the component is presented." ;
            sh:in ( "SECURITIES" "LEG_SECURITIES" "UNDERLYING_SECURITIES" "PARTIES" "ORDERS_AND_QUOTES" "TRADES" "COMMISSIONS_AND_FEES" "FINANCING" "PAYMENTS" "STIPULATIONS" "HEADER_AND_TRAILER" "MISCELLANEOUS" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/component_group> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the component is a repeating group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/is_repeating_group> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Field> ;
            sh:description "Fields directly contained by the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/fields> ],
        [ sh:defaultValue "GLOBAL" ;
            sh:description "Sharing scope of the component." ;
            sh:in ( "GLOBAL" "COMMON" "SPECIFIC" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/scope> ],
        [ sh:description "FIX business areas whose messages embed the Global Component." ;
            sh:in ( "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/gc_referenced_in> ],
        [ sh:datatype xsd:string ;
            sh:description "Names of other components conceptually identical to this one." ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/conceptually_identical_to> ],
        [ sh:datatype xsd:boolean ;
            sh:description "Applicable at the Instrument level." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_instrument> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> .

