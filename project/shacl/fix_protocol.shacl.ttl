            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/allocation_scenarios> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/ClearingServicePostTradeProcessingFormat> ;
