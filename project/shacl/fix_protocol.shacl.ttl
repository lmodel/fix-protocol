            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeAppendixSection> .

