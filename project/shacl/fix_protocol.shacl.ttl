        [ sh:description "Methods supported for computing post-trade allocations." ;
            sh:in ( "AVERAGE_PRICE" "EXECUTED_PRICE" ) ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_trade_allocation_pricing_methods> ],
        [ sh:description "Role labels used throughout the Allocation category prose." ;
            sh:in ( "INITIATOR" "RESPONDENT" ) ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/allocation_roles> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocationFragmentationFieldMap> ;
            sh:description "Per-message mapping of fragmentation-related fields used by the Allocation messages." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/fragmentation_field_map> ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PostTradeComponentDetail> ;
            sh:description "Components used exclusively by messages within a category." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_category_specific_components> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/RegistrationStatusDescription> ;
            sh:description "Descriptions tied to RegistStatus(506) values." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/registration_status_descriptions> ],
        [ sh:description "Business functions exposed by the Position Management Clearing Services." ;
            sh:in ( "POSITION_CHANGE_SUBMISSION" "POSITION_ADJUSTMENT" "EXERCISE_NOTICE" "ABANDONMENT_NOTICE" "MARGIN_DISPOSITION" "POSITION_PLEDGE" "REQUEST_FOR_POSITION" ) ;
            sh:order 15 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/clearing_services_for_position_management> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/TradeCaptureReportIdentifierRule> ;
            sh:description "Rules governing TradeCaptureReport(35=AE) identifier fields." ;
            sh:nodeKind sh:IRI ;
