            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-post-trade/post_message_groups> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/TradeCaptureReportUsage> ;
            sh:description "Usages described in the \"Trade Capture Report Usages\" sub-section of the Trade Capture Reporting category." ;
            sh:nodeKind sh:IRI ;
