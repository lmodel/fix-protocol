            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path schema1:url ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeBusinessArea> .

<https://w3id.org/lmodel/fix-protocol/fix-base/BusinessArea> a sh:NodeShape ;
    rdfs:comment "A top-level business area of the FIX Latest specification." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/MessageCategory> ;
            sh:description "Message categories defined within a business area." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/categories> ],
        [ sh:datatype xsd:string ;
            sh:description "Display title of the area." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:description "Identity of the business area." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path schema1:identifier ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the area." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/BusinessArea> .

<https://w3id.org/lmodel/fix-protocol/fix-base/ExtensionPack> a sh:NodeShape ;
    rdfs:comment "A unit of change to FIX Latest." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Qualitative size indicator (XXS..XXL)." ;
            sh:in ( "XXS" "XS" "S" "M" "L" "XL" "XXL" ) ;
            sh:maxCount 1 ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/size> ],
        [ sh:datatype xsd:string ;
            sh:description "Short descriptive title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the EP applies only to the FIX Session Layer." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_session_layer_only> ],
        [ sh:datatype xsd:integer ;
            sh:description "Sequential identifier of the Extension Pack." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/number> ],
        [ sh:datatype xsd:string ;
            sh:description "Narrative summary of what the EP introduces." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/enhancement_summary> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the EP applies only to the FIXML encoding." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_fixml_only> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/ExtensionPack> .

<https://w3id.org/lmodel/fix-protocol/fix-base/FIXDatatype> a sh:NodeShape ;
    rdfs:comment "A FIX Protocol datatype." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Reference standard for datatypes backed by an external code set." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:conformsTo ],
        [ sh:datatype xsd:integer ;
            sh:description "Footnote indicators attached to a datatype row." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/footnote_numbers> ],
        [ sh:datatype xsd:integer ;
            sh:description "Inclusive upper bound of a bounded-array index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/index_upper_bound> ],
        [ sh:datatype xsd:string ;
            sh:description "Prose definition of the datatype." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/definition> ],
        [ sh:description "ISO/IEC 11404:2007 GPD value space assigned to the datatype." ;
            sh:in ( "integer" "ordinal" "size" "real" "scaled" "character" "characterstring" "boolean" "set" "array" "time" "union" ) ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/value_space> ],
        [ sh:datatype xsd:integer ;
            sh:description "Numeric radix for scaled value-space datatypes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/radix> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True for datatypes not permitted in new designs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/deprecated_for_new_designs> ],
        [ sh:description "Canonical FIX datatype name." ;
            sh:in ( "int" "TagNum" "SeqNum" "NumInGroup" "DayOfMonth" "float" "Qty" "Price" "PriceOffset" "Amt" "Percentage" "char" "Boolean" "String" "MultipleCharValue" "MultipleStringValue" iso3166: iso4217: iso10383: "MonthYear" "UTCTimestamp" "UTCTimeOnly" "UTCDateOnly" "LocalMktDate" "TZTimeOnly" "TZTimestamp" "Length" "data" "Tenor" "Reserved100Plus" "Reserved1000Plus" "Reserved4000Plus" "XMLData" iso639: "LocalMktTime" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/datatype_name> ],
        [ sh:datatype xsd:integer ;
            sh:description "Inclusive lower bound of a bounded-array index." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/index_lower_bound> ],
        [ sh:datatype xsd:integer ;
            sh:description "Inclusive upper bound on the integer value space." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 12 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/maximum_value> ],
        [ sh:datatype xsd:integer ;
            sh:description "Inclusive lower bound on the integer value space." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/minimum_value> ],
        [ sh:description "Time-unit precision for time-bearing datatypes." ;
            sh:in ( "SECOND" "MILLISECOND" "MICROSECOND" "NANOSECOND" "PICOSECOND" "DAY" ) ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/time_unit> ],
        [ sh:datatype xsd:string ;
            sh:description "Character repertoire for character/string datatypes." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/repertoire> ],
        [ sh:datatype xsd:string ;
            sh:description "Additional value-space constraints." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/value_space_notes> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/FIXDatatype> .

<https://w3id.org/lmodel/fix-protocol/fix-base/FIXFamilyStandard> a sh:NodeShape ;
    rdfs:comment "A member standard of the FIX Family of Standards." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Display name of the element." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:name ],
        [ sh:description "Name of the session profile for session-layer variants." ;
            sh:in ( "FIX_4_2" "FIX4" "FIXT" "LFIXT" "FIXP" "SOFH" "FIXS" "AMQP" ) ;
            sh:maxCount 1 ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/session_profile> ],
        [ sh:datatype xsd:string ;
            sh:description "Version of the standard, if applicable." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path schema1:version ],
        [ sh:description "Named encoding, when layer is ENCODING." ;
            sh:in ( "TAGVALUE" "FIXML" "FAST" "SBE" "GPB" "JSON" "ASN_1" ) ;
            sh:maxCount 1 ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/encoding_name> ],
        [ sh:datatype xsd:string ;
            sh:description "Short acronym used to refer to the standard." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path schema1:alternateName ],
        [ sh:description "Related external resources." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <rdfs:seeAlso> ],
        [ sh:datatype xsd:string ;
            sh:description "Unique identifier (CURIE or local name) of the element." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/id> ],
        [ sh:datatype xsd:string ;
            sh:description "Free-text description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:description "The layer the standard belongs to." ;
            sh:in ( "APPLICATION" "ENCODING" "SESSION" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/layer> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/FIXFamilyStandard> .

<https://w3id.org/lmodel/fix-protocol/fix-base/FIXProtocolLimited> a sh:NodeShape ;
    rdfs:comment "The organization that maintains the FIX Protocol specification." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "High-level governance bodies that represent FPL." ;
            sh:in ( "GLOBAL_STEERING_COMMITTEE" "GLOBAL_TECHNICAL_COMMITTEE" "GLOBAL_PRODUCT_COMMITTEE" "GLOBAL_BUY_SIDE_COMMITTEE" "GLOBAL_MEMBER_SERVICES_COMMITTEE" "REGIONAL_COMMITTEE" ) ;
            sh:order 7 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/governance_bodies> ],
        [ sh:description "URL listing current FPL Member firms." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/member_firms_url> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Trading Community"^^xsd:string ;
            sh:description "Brand name used by the organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/brand_name> ],
        [ sh:description "Organization categories represented in FPL membership." ;
            sh:in ( "BUY_SIDE_FIRM" "SELL_SIDE_FIRM" "EXCHANGE" "ECN_ATS" "UTILITY" "VENDOR" "OTHER_ASSOCIATION" ) ;
            sh:order 6 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/member_types> ],
        [ sh:description "URL listing currently active FPL Working Groups." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/working_groups_url> ],
        [ sh:description "Regional Committees maintained by FPL." ;
            sh:in ( "AMERICAS" "ASIA_PACIFIC" "EMEA" "JAPAN" ) ;
            sh:order 9 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/regional_committees> ],
        [ sh:description "Global Product Committees maintained by FPL." ;
            sh:in ( "FIXED_INCOME_AND_CURRENCIES" "LISTED_PRODUCTS_AND_EXCHANGES" ) ;
            sh:order 8 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/product_committees> ],
        [ sh:description "URL listing Product and Regional Committees." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/committees_url> ],
        [ sh:datatype xsd:string ;
            sh:defaultValue "FIX Protocol Limited"^^xsd:string ;
            sh:description "Legal name of the organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:legalName ],
        [ sh:defaultValue "https://www.fixtrading.org"^^xsd:anyURI ;
            sh:description "Main website URL of the organization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path schema1:url ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/FIXProtocolLimited> .

<https://w3id.org/lmodel/fix-protocol/fix-base/Message> a sh:NodeShape ;
    rdfs:comment "A FIX application message." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Message category." ;
            sh:in ( "INDICATION" "EVENT_COMMUNICATION" "QUOTATION_NEGOTIATION" "MARKET_DATA" "MARKET_STRUCTURE_REFERENCE_DATA" "SECURITIES_REFERENCE_DATA" "PARTIES_REFERENCE_DATA" "PARTIES_ACTION" "SINGLE_GENERAL_ORDER_HANDLING" "ORDER_MASS_HANDLING" "CROSS_ORDERS" "MULTILEG_ORDERS" "LIST_PROGRAM_BASKET_TRADING" "ALLOCATION_AND_READY_TO_BOOK" "CONFIRMATION" "SETTLEMENT_INSTRUCTIONS" "TRADE_CAPTURE_REPORTING" "REGISTRATION_INSTRUCTIONS" "POSITIONS_MAINTENANCE" "COLLATERAL_MANAGEMENT" "MARGIN_REQUIREMENT_MANAGEMENT" "ACCOUNT_REPORTING" "TRADE_MANAGEMENT" "PAY_MANAGEMENT" "SETTLEMENT_STATUS_MANAGEMENT" "BUSINESS_MESSAGE_REJECTS" "NETWORK_STATUS_COMMUNICATION" "USER_MANAGEMENT" "APPLICATION_SEQUENCING" ) ;
            sh:maxCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/category> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Field> ;
            sh:description "Fields directly contained by the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/fields> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
            sh:description "Components referenced by the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/components> ],
        [ sh:datatype xsd:string ;
            sh:description "MsgType(35) wire value identifying the message." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/msg_type> ;
            sh:pattern "^[A-Za-z0-9]{1,3}$" ],
        [ sh:datatype xsd:string ;
            sh:description "PascalCase name of the message." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the message's purpose." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/Message> .

<https://w3id.org/lmodel/fix-protocol/fix-base/MessageCategory> a sh:NodeShape ;
    rdfs:comment "A message category within a business area." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Description of the category." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:description "Business area the element belongs to." ;
            sh:in ( "INTRODUCTION" "PRE_TRADE" "TRADE" "POST_TRADE" "INFRASTRUCTURE" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ sh:description "Identity of the message category." ;
            sh:in ( "INDICATION" "EVENT_COMMUNICATION" "QUOTATION_NEGOTIATION" "MARKET_DATA" "MARKET_STRUCTURE_REFERENCE_DATA" "SECURITIES_REFERENCE_DATA" "PARTIES_REFERENCE_DATA" "PARTIES_ACTION" "SINGLE_GENERAL_ORDER_HANDLING" "ORDER_MASS_HANDLING" "CROSS_ORDERS" "MULTILEG_ORDERS" "LIST_PROGRAM_BASKET_TRADING" "ALLOCATION_AND_READY_TO_BOOK" "CONFIRMATION" "SETTLEMENT_INSTRUCTIONS" "TRADE_CAPTURE_REPORTING" "REGISTRATION_INSTRUCTIONS" "POSITIONS_MAINTENANCE" "COLLATERAL_MANAGEMENT" "MARGIN_REQUIREMENT_MANAGEMENT" "ACCOUNT_REPORTING" "TRADE_MANAGEMENT" "PAY_MANAGEMENT" "SETTLEMENT_STATUS_MANAGEMENT" "BUSINESS_MESSAGE_REJECTS" "NETWORK_STATUS_COMMUNICATION" "USER_MANAGEMENT" "APPLICATION_SEQUENCING" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/category> ],
        [ sh:datatype xsd:string ;
            sh:description "Display title of the category." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Message> ;
            sh:description "Messages defined within the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/MessageCategory> .

<https://w3id.org/lmodel/fix-protocol/fix-base/UDFTagRange> a sh:NodeShape ;
    rdfs:comment "A reserved range of tag numbers for User Defined Fields." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Usage policy assigned to the range." ;
            sh:in ( "INTER_FIRM_REGISTERED" "INTER_FIRM_BILATERAL" "GTC_REGULATORY_LEGACY" "WIP_CHINA" "INTERNAL_FIRM" "GTC_OTC_DERIVATIVES" "GTC_RESERVED" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/usage> ],
        [ sh:datatype xsd:string ;
            sh:description "Identifier of the range." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/range_id> ],
        [ sh:datatype xsd:integer ;
            sh:description "Upper bound of the tag range. Required for all ``usage`` values except ``GTC_RESERVED`` (which is open-ended, 50000+). Downstream validators should enforce this; the constraint cannot be expressed here because LinkML's ``equals_string`` operator only accepts string-ranged slots and ``usage`` is an enum." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/high_tag> ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when tags in the range must be registered." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/requires_registration> ],
        [ sh:datatype xsd:string ;
            sh:description "Notes on the range's intended use." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:integer ;
            sh:description "Inclusive lower bound of the range." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/low_tag> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/UDFTagRange> .

<https://w3id.org/lmodel/fix-protocol/fix-infrastructure/BusinessRejectReasonDescription> a sh:NodeShape ;
