            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/introduced_in> ],
        [ sh:datatype xsd:integer ;
            sh:description "Footnote indicator on a component-table row." ;
