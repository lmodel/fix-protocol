<https://w3id.org/lmodel/fix-protocol/fix-base/Component> a sh:NodeShape ;
    rdfs:comment "A FIX component — a named set of related fields." ;
    sh:closed false ;
    sh:ignoredProperties ( <https://w3id.org/lmodel/fix-protocol/fix-base/gc_id> <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> <https://w3id.org/lmodel/fix-protocol/fix-base/category> <https://w3id.org/lmodel/fix-protocol/fix-base/component_group> <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_underlying> <https://w3id.org/lmodel/fix-protocol/fix-base/gc_referenced_in> <https://w3id.org/lmodel/fix-protocol/fix-base/conceptually_identical_to> <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_leg> <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_instrument> rdf:type ) ;
    sh:property [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Field> ;
            sh:description "Fields directly contained by the enclosing element." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/fields> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
            sh:description "Components nested within this component." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/nested_components> ],
        [ sh:datatype xsd:string ;
            sh:description "PascalCase name of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path schema1:name ],
        [ sh:datatype xsd:string ;
            sh:description "Description of the component." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:description ],
        [ sh:datatype xsd:boolean ;
            sh:description "True when the component is a repeating group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/is_repeating_group> ],
        [ sh:description "Sharing scope of the component." ;
            sh:in ( "GLOBAL" "COMMON" "SPECIFIC" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 2 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-base/scope> ] ;
    sh:targetClass <https://w3id.org/lmodel/fix-protocol/fix-base/Component> .

<https://w3id.org/lmodel/fix-protocol/fix-base/Field> a sh:NodeShape ;
