            sh:order 3 ;
            sh:path <https://w3id.org/lmodel/fix-protocol/fix-pre-trade/category_components_note> ],
        [ sh:class <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocationStatusDescription> ;
