    rdfs:seeAlso "https://www.fixtrading.org/standards/fix-latest-online/business-area-trade/"^^xsd:anyURI ;
    skos:altLabel "Orders and Executions",
        "Trade" ;
    skos:inScheme "https://w3id.org/lmodel/fix-protocol/fix-trade"^^xsd:anyURI ;
    skos:mappingRelation "fix_trade:TradeBusinessArea"^^xsd:anyURI ;
    linkml:class_uri "https://w3id.org/lmodel/fix-protocol/fix-trade/TradeBusinessArea"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/lmodel/fix-protocol/fix-trade/TradeBusinessArea"^^xsd:anyURI ;
    linkml:description "Tree-root container for the Trade (Orders and Executions) business area of FIX Latest." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/lmodel/fix-protocol/TradeBusinessArea_components>,
        <https://w3id.org/lmodel/fix-protocol/TradeBusinessArea_messages>,
        <https://w3id.org/lmodel/fix-protocol/TradeBusinessArea_publisher>,
        <https://w3id.org/lmodel/fix-protocol/TradeBusinessArea_title>,
        <https://w3id.org/lmodel/fix-protocol/TradeBusinessArea_trade_area>,
        <https://w3id.org/lmodel/fix-protocol/published_version>,
        <https://w3id.org/lmodel/fix-protocol/referenced_global_components>,
        <https://w3id.org/lmodel/fix-protocol/trade_category_sections>,
        <https://w3id.org/lmodel/fix-protocol/trade_common_component_details>,
        <https://w3id.org/lmodel/fix-protocol/trade_common_components>,
        <https://w3id.org/lmodel/fix-protocol/trade_components_overview_note>,
        <https://w3id.org/lmodel/fix-protocol/trade_diagram_conventions>,
        <https://w3id.org/lmodel/fix-protocol/trade_footnotes>,
        <https://w3id.org/lmodel/fix-protocol/trade_introduction>,
        <https://w3id.org/lmodel/fix-protocol/trade_message_diagram_template_url>,
        <https://w3id.org/lmodel/fix-protocol/trade_messages_overview_note> ;
    linkml:tree_root true .

<https://w3id.org/lmodel/fix-protocol/InfrastructureBusinessArea> a linkml:ClassDefinition ;
    OIO:inSubset <https://w3id.org/lmodel/fix-protocol/infrastructure> ;
    rdfs:seeAlso "https://www.fixtrading.org/standards/fix-latest-online/business-area-infrastructure/"^^xsd:anyURI ;
    skos:altLabel "Infrastructure" ;
