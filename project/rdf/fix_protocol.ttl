    skos:mappingRelation "fix_infrastructure:InfrastructureBusinessArea"^^xsd:anyURI ;
    skos:relatedMatch "fixp:FixpSessionExchange"^^xsd:anyURI ;
    linkml:class_uri "https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureBusinessArea"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureBusinessArea"^^xsd:anyURI ;
    linkml:description "Tree-root container for the Infrastructure business area of FIX Latest." ;
