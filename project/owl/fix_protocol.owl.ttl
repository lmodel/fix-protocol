<https://w3id.org/lmodel/fix-protocol/fix-base/title> a owl:DatatypeProperty ;
    rdfs:label "title" ;
    rdfs:range xsd:string ;
    skos:definition "Display title." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/category> a owl:ObjectProperty ;
    rdfs:label "category" ;
    rdfs:range fix_protocol:MessageCategoryEnum ;
    skos:definition "Message category." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/component_name> a owl:DatatypeProperty ;
    rdfs:label "component_name" ;
    rdfs:range xsd:string ;
    skos:definition "PascalCase name of the component." ;
    skos:inScheme fix_protocol:fix-base .

xsd:integer a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:integer ;
            owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] .

<https://w3id.org/lmodel/fix-protocol/fix-base/description> a owl:DatatypeProperty ;
    rdfs:label "description" ;
    rdfs:range xsd:string ;
    skos:definition "Free-text description." ;
    skos:inScheme fix_protocol:fix-base .


