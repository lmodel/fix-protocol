<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/layout_url> a owl:DatatypeProperty ;
    rdfs:label "layout_url" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URL of the detailed message- or component-layout." ;
    skos:inScheme fix_protocol:fix-pre-trade .

<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/repetition> a owl:ObjectProperty ;
    rdfs:label "repetition" ;
    rdfs:range fix_protocol:ComponentRepetition ;
    skos:definition "REPEATING or NON_REPEATING." ;
    skos:inScheme fix_protocol:fix-pre-trade .

<https://w3id.org/lmodel/fix-protocol/fix-base/messages> a owl:ObjectProperty ;
    rdfs:label "messages" ;
    rdfs:range <https://w3id.org/lmodel/fix-protocol/fix-base/Message> ;
    skos:definition "Messages defined within the enclosing element." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/message_name> a owl:DatatypeProperty ;
    rdfs:label "message_name" ;
    rdfs:range xsd:string ;
    skos:definition "PascalCase name of the message." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/msg_type> a owl:DatatypeProperty ;
    rdfs:label "msg_type" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:string [ a rdfs:Datatype ;
                        owl:onDatatype xsd:string ;
                        owl:withRestrictions ( [ xsd:pattern "^[A-Za-z0-9]{1,3}$" ] ) ] ) ] ;
    skos:definition "MsgType(35) wire value identifying the message." ;
    skos:inScheme fix_protocol:fix-base .

