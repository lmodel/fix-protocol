<https://w3id.org/lmodel/fix-protocol/fix-base/index_upper_bound> a owl:DatatypeProperty ;
    rdfs:label "index_upper_bound" ;
    rdfs:range xsd:integer ;
    skos:definition "Inclusive upper bound of a bounded-array index." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/introduction_text> a owl:DatatypeProperty ;
