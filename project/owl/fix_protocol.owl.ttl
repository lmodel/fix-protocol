<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/pre_layout_field_tag> a owl:DatatypeProperty ;
    rdfs:label "pre_layout_field_tag" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "FIX tag number drawn from the Tag column when the row is a field (i.e. layout_kind = FIELD). Absent for COMPONENT rows." ;
    skos:inScheme fix_protocol:fix-pre-trade .

<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/pre_layout_kind> a owl:ObjectProperty ;
    rdfs:label "pre_layout_kind" ;
    rdfs:range fix_protocol:PreTradeLayoutRowKindEnum ;
    skos:definition "Row kind — either a FIX field (numeric Tag) or an embedded component (literal \"Component\" in the Tag column of the source table)." ;
    skos:inScheme fix_protocol:fix-pre-trade .

<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/pre_layout_nested> a owl:DatatypeProperty ;
    rdfs:label "pre_layout_nested" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the row appears nested under a repeating-group counter (i.e. its Tag column is prefixed with the \"→\" arrow in the source table)." ;
    skos:inScheme fix_protocol:fix-pre-trade .

<https://w3id.org/lmodel/fix-protocol/fix-pre-trade/pre_layout_required> a owl:DatatypeProperty ;
    rdfs:label "pre_layout_required" ;
    rdfs:range xsd:boolean ;
