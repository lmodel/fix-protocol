<https://w3id.org/lmodel/fix-protocol/fix-base/committees_url> a owl:DatatypeProperty ;
    rdfs:label "committees_url" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URL listing Product and Regional Committees." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/component_group> a owl:ObjectProperty ;
    rdfs:label "component_group" ;
