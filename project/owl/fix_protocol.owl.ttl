<https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_layout_field_tag> a owl:DatatypeProperty ;
    rdfs:label "infra_layout_field_tag" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
