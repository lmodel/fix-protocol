<https://w3id.org/lmodel/fix-protocol/fix-base/enhancement_summary> a owl:DatatypeProperty ;
    rdfs:label "enhancement_summary" ;
    rdfs:range xsd:string ;
    skos:definition "Narrative summary of what the EP introduces." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/external_code_set> a owl:DatatypeProperty ;
    rdfs:label "external_code_set" ;
    rdfs:range xsd:string ;
    skos:definition "Reference standard for datatypes backed by an external code set." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/field_name> a owl:DatatypeProperty ;
    rdfs:label "field_name" ;
    rdfs:range xsd:string ;
    skos:definition "PascalCase name of the field." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/gc_id> a owl:DatatypeProperty ;
    rdfs:label "gc_id" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "Numeric component identifier extracted from the FIX Latest \"Global Components\" page anchor ID (e.g. \"comp1057-1\" → 1057). Stable across Extension Packs and shared with the FIX Orchestra repository." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/high_tag> a owl:DatatypeProperty ;
    rdfs:label "high_tag" ;
    rdfs:range xsd:integer ;
    skos:definition "Inclusive upper bound of the range (absent for open-ended)." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/id> a owl:DatatypeProperty ;
    rdfs:label "id" ;
    rdfs:range xsd:string ;
    skos:definition "Unique identifier (CURIE or local name) of the element." ;
