            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/component_group> ],
        [ a owl:Restriction ;
            owl:allValuesFrom fix_protocol:ComponentGroup ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/component_group> ],
