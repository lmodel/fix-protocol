fix_protocol:InfrastructureGlobalComponentName a owl:Class ;
    rdfs:label "InfrastructureGlobalComponentName" ;
    skos:definition "Names of the Global Components (declared in the FIX Latest \"Global Components\" page) that the Infrastructure business-area messages explicitly reference. Global Components are reusable component blocks used across two or more business areas." ;
    skos:inScheme fix_protocol:fix-infrastructure ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/InfrastructureGlobalComponentName#ApplicationSequenceControl> .

fix_protocol:RegistrationTransactionTypeEnum a owl:Class ;
