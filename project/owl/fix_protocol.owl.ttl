        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/datatype> ],
        [ a owl:Restriction ;
            owl:allValuesFrom fix_protocol:FieldRequirement ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/requirement> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
