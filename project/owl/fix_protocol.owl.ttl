            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_leg> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/conceptually_identical_to> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_underlying> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_instrument> ],
        [ a owl:Restriction ;
