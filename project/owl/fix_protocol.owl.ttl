    skos:definition "True for datatypes not permitted in new designs." ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/encoding_name> a owl:ObjectProperty ;
    rdfs:label "encoding_name" ;
