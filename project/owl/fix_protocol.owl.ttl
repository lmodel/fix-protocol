            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/infra_global_component_name> ] ;
    skos:definition "A reference from the Infrastructure business area to a Global Component declared on the FIX Latest \"Global Components\" page. Records the component name, the FIX tags it contributes, and the Infrastructure categories and messages that embed it." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/InfrastructureGlobalComponentReference> ;
    skos:inScheme fix_protocol:fix-infrastructure .

