<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_footnotes> a owl:ObjectProperty ;
    rdfs:label "trade_footnotes" ;
    rdfs:range <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeComponentTableFootnote> ;
    skos:definition "Footnotes attached to the area-wide components table." ;
