            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_footnote_text> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/component_name> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_introduced_in> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/component_name> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 25 ] ) ] ) ] ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_footnote_number> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_introduced_in> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_footnote_number> ] ;
    skos:definition "A footnote on the area-wide components table." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeComponentTableFootnote> ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/TradeFragmentationEntry> a owl:Class ;
    rdfs:label "TradeFragmentationEntry" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_repeating_group> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_total_entries_field> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_message> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_total_entries_field> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_message> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_total_entries_field> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_repeating_group> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_message> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_repeating_group> ] ;
    skos:definition "One row of a fragmentation table published in a Trade category (currently only List/Program/Basket Trading) identifying a message that may be fragmented, the \"Total Entries\" field used to indicate the total count across all fragments of the batch, and the verbatim description of the repeating group that may be fragmented." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeFragmentationEntry> ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/TradeMessageGroup> a owl:Class ;
    rdfs:label "TradeMessageGroup" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_group_title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeMessageDetail> ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/messages> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_group_title> ],
        [ a owl:Restriction ;
            owl:allValuesFrom <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeOrdStatusPrecedenceEntry> ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_precedence_entries> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_group_title> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_precedence_entries> ] ;
    skos:definition "Purpose-grouped sub-section inside a category's Messages sub-section (e.g. \"New Order Single\", \"Execution Reports\", \"Order Cancel Requests\" under Single/General Order Handling)." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeMessageGroup> ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/TradeOrdStatusPrecedenceEntry> a owl:Class ;
    rdfs:label "TradeOrdStatusPrecedenceEntry" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:integer ;
                                owl:withRestrictions ( [ xsd:maxInclusive 11 ] ) ] ) ] ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_precedence> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_label> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/description> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_label> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_precedence> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_precedence> ] ;
    skos:definition "One row of the OrdStatus(39) precedence table published in the Execution Reports purpose-group of the Single/General Order Handling category. Defines the precedence ranking used to resolve simultaneous state transitions on an order, paired with the human-readable OrdStatus label and its descriptive prose." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-trade/TradeOrdStatusPrecedenceEntry> ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_appendix_category> a owl:DatatypeProperty ;
    rdfs:label "trade_appendix_category" ;
    rdfs:range xsd:string ;
    skos:definition "Identifier for an appendix section — either the Trade category name as printed in the heading (e.g. \"CrossOrders\", \"MultilegOrders\", \"OrderMassHandling\", \"ProgramTrading\", \"SingleGeneralOrderHandling\") or the literal \"Common\" for the common-components appendix." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_area> a owl:ObjectProperty ;
    rdfs:label "trade_area" ;
    rdfs:range fix_protocol:BusinessAreaEnum ;
    skos:definition "Identity of the business area the chapter describes." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_category_background> a owl:DatatypeProperty ;
    rdfs:label "trade_category_background" ;
    rdfs:range xsd:string ;
    skos:definition "Optional \"Background\" prose preceding a category's message descriptions (e.g. the Cross Order Handling chapter's cross-trade overview)." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_category_components_note> a owl:DatatypeProperty ;
    rdfs:label "trade_category_components_note" ;
    rdfs:range xsd:string ;
    skos:definition "Intro prose of a category's Components sub-section." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_components_overview_note> a owl:DatatypeProperty ;
    rdfs:label "trade_components_overview_note" ;
    rdfs:range xsd:string ;
    skos:definition "Intro prose of the area-wide Components sub-section." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_diagram_conventions> a owl:DatatypeProperty ;
    rdfs:label "trade_diagram_conventions" ;
    rdfs:range xsd:string ;
    skos:definition "Sentence describing diagram conventions used in the chapter." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_footnote_text> a owl:DatatypeProperty ;
    rdfs:label "trade_footnote_text" ;
    rdfs:range xsd:string ;
    skos:definition "Footnote text." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_message> a owl:DatatypeProperty ;
    rdfs:label "trade_fragmentation_message" ;
    rdfs:range xsd:string ;
    skos:definition "Message that may be fragmented — verbatim text from the Message column of the fragmentation table (e.g. \"NewOrderList(35=E)\")." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_repeating_group> a owl:DatatypeProperty ;
    rdfs:label "trade_fragmentation_repeating_group" ;
    rdfs:range xsd:string ;
    skos:definition "Verbatim description of the repeating group that may be fragmented — from the table's third column." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_fragmentation_total_entries_field> a owl:DatatypeProperty ;
    rdfs:label "trade_fragmentation_total_entries_field" ;
    rdfs:range xsd:string ;
    skos:definition "Name and tag of the \"Total Entries\" field used to indicate the total count across all fragments of the batch (e.g. \"TotNoOrders(68)\")." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_group_title> a owl:DatatypeProperty ;
    rdfs:label "trade_group_title" ;
    rdfs:range xsd:string ;
    skos:definition "Purpose-group heading inside a category's Messages sub-section." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_introduced_in> a owl:DatatypeProperty ;
    rdfs:label "trade_introduced_in" ;
    rdfs:range xsd:string ;
    skos:definition "FIX version or Extension Pack that introduced the component." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_introduction> a owl:DatatypeProperty ;
    rdfs:label "trade_introduction" ;
    rdfs:range xsd:string ;
    skos:definition "Prose introduction of the chapter." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_is_common> a owl:DatatypeProperty ;
    rdfs:label "trade_is_common" ;
    rdfs:range xsd:boolean ;
    skos:definition "True when the component is declared as a Common Component." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_layout_description> a owl:DatatypeProperty ;
    rdfs:label "trade_layout_description" ;
    rdfs:range xsd:string ;
    skos:definition "Free-text content of the Description column of the row (may be empty)." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_layout_element_name> a owl:DatatypeProperty ;
    rdfs:label "trade_layout_element_name" ;
    rdfs:range xsd:string ;
    skos:definition "Element name as printed in the Name column — either the FIX field name or the component name." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_layout_field_tag> a owl:DatatypeProperty ;
    rdfs:label "trade_layout_field_tag" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 0 ] ) ] ) ] ;
    skos:definition "FIX tag number drawn from the Tag column when the row is a field (i.e. layout_kind = FIELD). Absent for COMPONENT rows." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_layout_kind> a owl:ObjectProperty ;
    rdfs:label "trade_layout_kind" ;
    rdfs:range fix_protocol:TradeLayoutRowKindEnum ;
    skos:definition "Row kind — either a FIX field (numeric Tag) or an embedded component (literal \"Component\" in the Tag column of the source table)." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_layout_nested> a owl:DatatypeProperty ;
    rdfs:label "trade_layout_nested" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the row appears nested under a repeating-group counter (i.e. its Tag column is prefixed with the \"→\" arrow in the source table)." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_layout_required> a owl:DatatypeProperty ;
    rdfs:label "trade_layout_required" ;
    rdfs:range xsd:boolean ;
    skos:definition "Whether the field or component is required, as printed in the Req'd column of the source layout table (\"Y\" / \"N\")." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_message_diagram_template_url> a owl:DatatypeProperty ;
    rdfs:label "trade_message_diagram_template_url" ;
    rdfs:range xsd:anyURI ;
    skos:definition "URL of the \"Message Diagram Templates\" page referenced by the chapter introduction." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_messages_overview_note> a owl:DatatypeProperty ;
    rdfs:label "trade_messages_overview_note" ;
    rdfs:range xsd:string ;
    skos:definition "Intro prose of the area-wide Messages sub-section." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_label> a owl:DatatypeProperty ;
    rdfs:label "trade_ord_status_label" ;
    rdfs:range xsd:string ;
    skos:definition "Human-readable OrdStatus(39) label as printed in the Execution Reports precedence table (e.g. \"Pending Cancel\", \"Done for Day\", \"Filled\")." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_ord_status_precedence> a owl:DatatypeProperty ;
    rdfs:label "trade_ord_status_precedence" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:integer [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:minInclusive 1 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:integer ;
                        owl:withRestrictions ( [ xsd:maxInclusive 11 ] ) ] ) ] ;
    skos:definition "Precedence rank (1 = lowest, higher numbers take precedence) of an OrdStatus(39) value used to resolve simultaneous state transitions on an order." ;
    skos:inScheme fix_protocol:fix-trade .

<https://w3id.org/lmodel/fix-protocol/fix-trade/trade_sole_category> a owl:ObjectProperty ;
    rdfs:label "trade_sole_category" ;
    rdfs:range fix_protocol:TradeCategoryEnum ;
    skos:definition "Single category that actually uses the component." ;
    skos:inScheme fix_protocol:fix-trade .

fix_protocol:AllocationRoleEnum a owl:Class ;
    rdfs:label "AllocationRoleEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/AllocationRoleEnum#INITIATOR> <https://w3id.org/lmodel/fix-protocol/AllocationRoleEnum#RESPONDENT> ) ;
    skos:definition "Role labels used throughout the Allocation category prose to designate the sender and receiver of an AllocationInstruction." ;
    skos:inScheme fix_protocol:fix-post-trade ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/AllocationRoleEnum#INITIATOR>,
        <https://w3id.org/lmodel/fix-protocol/AllocationRoleEnum#RESPONDENT> .

fix_protocol:AllocationStatusEnum a owl:Class ;
    rdfs:label "AllocationStatusEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_0> <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_1> <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_2> <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_3> ) ;
    skos:closeMatch <https://w3id.org/lmodel/common-domain-model/WorkflowStatusEnum> ;
    skos:definition "AllocStatus(87) values used in allocation acknowledgement messages." ;
    skos:inScheme fix_protocol:fix-post-trade ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_0>,
        <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_1>,
        <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_2>,
        <https://w3id.org/lmodel/fix-protocol/fix-post-trade/AllocStatus_3> .

fix_protocol:ApplicationSequenceControlFieldName a owl:Class ;
    rdfs:label "ApplicationSequenceControlFieldName" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplID> <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplSeqNum> <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplLastSeqNum> <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplResendFlag> ) ;
    skos:definition "Tags contributed by the ApplicationSequenceControl global component (used by Application Sequencing messages and by all FIX messages representing reports)." ;
    skos:inScheme fix_protocol:fix-infrastructure ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplID>,
        <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplLastSeqNum>,
        <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplResendFlag>,
        <https://w3id.org/lmodel/fix-protocol/ApplicationSequenceControlFieldName#ApplSeqNum> .

fix_protocol:CollateralManagementUsageEnum a owl:Class ;
    rdfs:label "CollateralManagementUsageEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/CollateralManagementUsageEnum#SECURITIES_FINANCING_COLLATERALIZATION> <https://w3id.org/lmodel/fix-protocol/CollateralManagementUsageEnum#CLEARING_HOUSE_COLLATERALIZATION> ) ;
    skos:definition "Documented uses of the Collateral Management messages." ;
    skos:inScheme fix_protocol:fix-post-trade ;
    skos:relatedMatch <https://w3id.org/lmodel/common-domain-model/CollateralMarginTypeEnum> ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/CollateralManagementUsageEnum#CLEARING_HOUSE_COLLATERALIZATION>,
        <https://w3id.org/lmodel/fix-protocol/CollateralManagementUsageEnum#SECURITIES_FINANCING_COLLATERALIZATION> .

fix_protocol:FPLProductGroup a owl:Class ;
    rdfs:label "FPLProductGroup" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/FPLProductGroup#FIXED_INCOME_AND_CURRENCIES> <https://w3id.org/lmodel/fix-protocol/FPLProductGroup#LISTED_PRODUCTS_AND_EXCHANGES> ) ;
    skos:definition "Global Product Committees maintained by FIX Protocol Limited." ;
    skos:inScheme fix_protocol:fix-base ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/FPLProductGroup#FIXED_INCOME_AND_CURRENCIES>,
        <https://w3id.org/lmodel/fix-protocol/FPLProductGroup#LISTED_PRODUCTS_AND_EXCHANGES> .

fix_protocol:InfrastructureLayoutRowKindEnum a owl:Class ;
    rdfs:label "InfrastructureLayoutRowKindEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/InfrastructureLayoutRowKindEnum#FIELD> <https://w3id.org/lmodel/fix-protocol/InfrastructureLayoutRowKindEnum#COMPONENT> ) ;
    skos:definition "Discriminator for a row in an Infrastructure message- or component-layout table: either a FIX field (numeric Tag column) or an embedded component (literal \"Component\" in the Tag column)." ;
    skos:inScheme fix_protocol:fix-infrastructure ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/InfrastructureLayoutRowKindEnum#COMPONENT>,
        <https://w3id.org/lmodel/fix-protocol/InfrastructureLayoutRowKindEnum#FIELD> .

fix_protocol:NetworkRequestTypeEnum a owl:Class ;
    rdfs:label "NetworkRequestTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/NetworkRequestType_1> <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/NetworkRequestType_4> ) ;
    skos:definition "Values of NetworkRequestType(935) explicitly cited in the NetworkCounterpartySystemStatusRequest(35=BC) prose." ;
    skos:inScheme fix_protocol:fix-infrastructure ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/NetworkRequestType_1>,
        <https://w3id.org/lmodel/fix-protocol/fix-infrastructure/NetworkRequestType_4> .

fix_protocol:NetworkStatusScenarioEnum a owl:Class ;
    rdfs:label "NetworkStatusScenarioEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/NetworkStatusScenarioEnum#SCENARIO_A> <https://w3id.org/lmodel/fix-protocol/NetworkStatusScenarioEnum#SCENARIO_B> ) ;
    skos:definition "Network Status Communication usage scenarios documented in the chapter (Scenario A: hub-and-spoke; Scenario B: global brokerage region availability)." ;
    skos:inScheme fix_protocol:fix-infrastructure ;
    skos:relatedMatch <https://w3id.org/lmodel/fluxnova-bpm-platform/ProcessDefinition> ;
    linkml:permissible_values <https://w3id.org/lmodel/fix-protocol/NetworkStatusScenarioEnum#SCENARIO_A>,
        <https://w3id.org/lmodel/fix-protocol/NetworkStatusScenarioEnum#SCENARIO_B> .

fix_protocol:PositionMaintenanceActionEnum a owl:Class ;
    rdfs:label "PositionMaintenanceActionEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PosMaintAction_1> <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PosMaintAction_2> <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PosMaintAction_3> <https://w3id.org/lmodel/fix-protocol/fix-post-trade/PosMaintAction_4> ) ;
    skos:definition "PosMaintAction(712) values." ;
