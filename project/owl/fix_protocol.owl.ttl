<https://w3id.org/lmodel/fix-protocol/fix-base/CommonComponent> a owl:Class ;
    rdfs:label "CommonComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ a owl:Restriction ;
            owl:allValuesFrom fix_protocol:BusinessAreaEnum ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty fix_protocol:scope ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty fix_protocol:scope ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty fix_protocol:scope ],
        <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
    skos:closeMatch <https://w3id.org/lmodel/fix-orchestra/ComponentType> ;
    skos:definition "A component used only by messages within a single business area." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-base/CommonComponent> ;
    skos:inScheme fix_protocol:fix-base .

<https://w3id.org/lmodel/fix-protocol/fix-base/SpecificComponent> a owl:Class ;
    rdfs:label "SpecificComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom fix_protocol:MessageCategoryEnum ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/category> ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty fix_protocol:scope ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty fix_protocol:scope ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/category> ],
        [ a owl:Restriction ;
            owl:allValuesFrom fix_protocol:BusinessAreaEnum ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/business_area> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty fix_protocol:scope ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/category> ],
        <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
    skos:closeMatch <https://w3id.org/lmodel/fix-orchestra/ComponentType> ;
    skos:definition "A component used only by messages within a single category." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-base/SpecificComponent> ;
    skos:inScheme fix_protocol:fix-base .

