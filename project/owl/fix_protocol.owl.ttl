            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/gc_id> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_underlying> ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/gc_id> ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty <https://w3id.org/lmodel/fix-protocol/fix-base/applies_to_underlying> ],
        <https://w3id.org/lmodel/fix-protocol/fix-base/Component> ;
    skos:closeMatch <https://w3id.org/lmodel/fix-orchestra/ComponentType> ;
    skos:definition "A component shared by messages of two or more business areas." ;
    skos:exactMatch <https://w3id.org/lmodel/fix-protocol/fix-base/GlobalComponent> ;
    skos:inScheme fix_protocol:fix-base .

